# Copy this file to ".env" in the same folder and fill in real values.
# Never commit the real ".env" file.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=financial_system
PORT=5000

# Any random string, at least 32 characters long. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long

# Comma-separated list of origins allowed to call this API from a browser.
# Defaults to http://localhost:5173 (the frontend's Vite dev port) if unset.
CORS_ORIGIN=http://localhost:5173
